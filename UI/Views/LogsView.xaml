<UserControl x:Class="FolderSync.UI.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="20,10,20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource Logs.Title}" Style="{StaticResource PageTitleTextStyle}"/>
                
                <Button Grid.Column="2" Content="{DynamicResource Logs.Refresh}" Command="{Binding RefreshCommand}" 
                        Style="{StaticResource SecondaryActionButtonStyle}" materialDesign:ButtonAssist.CornerRadius="18" Margin="0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：日志文件列表 -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,10,0" UniformCornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="14">
                        <TextBlock Text="{DynamicResource Logs.History}" FontWeight="SemiBold"/>
                    </Border>
                    
                    <ListBox Grid.Row="1" ItemsSource="{Binding LogFiles}" SelectedItem="{Binding SelectedLogFile}" Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <materialDesign:PackIcon Kind="FileDocumentOutline" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Kind}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{Binding LastModified, StringFormat=yyyy-MM-dd HH:mm:ss}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Style.Triggers>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBox">
                                                    <TextBlock Text="{DynamicResource Logs.EmptyFiles}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                    </ListBox>
                </Grid>
            </materialDesign:Card>

            <!-- 右侧：仅展示文件信息与打开入口 -->
            <materialDesign:Card Grid.Column="1" Margin="10,0,0,0" UniformCornerRadius="10">
                <StackPanel Margin="18">
                    <materialDesign:PackIcon Kind="FileDocumentArrowRightOutline"
                                             Width="42"
                                             Height="42"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                                             Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding SelectedLogTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{DynamicResource Logs.ContentHint}"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{DynamicResource Logs.DirectoryLabel}"
                               Margin="0,18,0,4"
                               FontWeight="SemiBold"/>
                    <TextBox Text="{Binding LogDirectory}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Logs.PathLabel}"
                               Margin="0,8,0,4"
                               FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SelectedLogPath}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="72"/>
                    <Button Content="{DynamicResource Logs.OpenExternal}"
                            Command="{Binding OpenInEditorCommand}"
                            IsEnabled="{Binding IsLogSelected}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
