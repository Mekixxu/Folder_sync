<UserControl x:Class="FolderSync.UI.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="20,10,20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource Tasks.Title}" Style="{StaticResource PageTitleTextStyle}"/>
                
                <Button Grid.Column="2" Content="{DynamicResource Tasks.NewTask}" Command="{Binding CreateNewTaskCommand}" 
                        Style="{StaticResource PrimaryActionButtonStyle}" materialDesign:ButtonAssist.CornerRadius="18" Margin="0"/>
            </Grid>
        </Border>

        <!-- 批量操作和分析进度 -->
        <materialDesign:Card Grid.Row="1" Margin="20,12,20,0" Padding="14" UniformCornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Tasks.BulkTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Text="{Binding AnalysisStatusText}" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" FontSize="{StaticResource FontMeta}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource Tasks.Analyze}"
                        Command="{Binding AnalyzeSelectedTasksCommand}"
                        Style="{StaticResource SecondaryActionButtonStyle}"/>
                    <Button Content="{DynamicResource Tasks.Execute}"
                        Command="{Binding ExecuteSelectedTasksCommand}"
                        Style="{StaticResource SecondaryActionButtonStyle}"/>
                    <Button Content="{DynamicResource Tasks.Sync}"
                        Command="{Binding SyncSelectedTasksCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}" Margin="0"/>
                </StackPanel>

                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="8"
                         Margin="0,12,0,2"
                         Maximum="{Binding AnalysisProgressMaximum}"
                         Value="{Binding AnalysisProgressValue}"
                         Visibility="{Binding IsAnalysisProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </materialDesign:Card>

        <!-- 任务列表区域 -->
        <ListView Grid.Row="2" Margin="20" ItemsSource="{Binding Tasks}" HorizontalContentAlignment="Stretch">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card Margin="0,5,0,5" Padding="14" UniformCornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>

                            <!-- 分析状态图标（✅ 可点击查看分析） -->
                            <Button Grid.Column="1"
                                    Command="{Binding DataContext.OpenTaskAnalysisCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="{DynamicResource Tasks.AnalysisStatusTip}"
                                    Padding="4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="{Binding AnalysisStatusIcon}"
                                                         Foreground="{Binding AnalysisStatusColor}"
                                                         Width="24"
                                                         Height="24"/>
                            </Button>

                            <!-- 中间任务详情 -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="{Binding TaskName}" FontSize="16" FontWeight="Bold"/>
                                    <Border Background="{StaticResource AppSurfaceAltBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding SyncMode}" FontSize="{StaticResource FontMeta}" Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </Border>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <materialDesign:PackIcon Kind="FolderSearchOutline" Width="16" Height="16" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SourcePath}" Foreground="{StaticResource SecondaryTextBrush}" Margin="5,0,10,0" VerticalAlignment="Center"/>
                                    
                                    <materialDesign:PackIcon Kind="ArrowRight" Width="16" Height="16" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    
                                    <materialDesign:PackIcon Kind="FolderUploadOutline" Width="16" Height="16" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding DestPath}" Foreground="{StaticResource SecondaryTextBrush}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <TextBlock Text="{Binding ScheduleInfo}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="{StaticResource FontMeta}" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- 右侧三点菜单 -->
                            <materialDesign:PopupBox Grid.Column="3"
                                                     HorizontalAlignment="Right"
                                                     VerticalAlignment="Center"
                                                     PlacementMode="BottomAndAlignRightEdges">
                                <materialDesign:PopupBox.ToggleContent>
                                    <materialDesign:PackIcon Kind="DotsVertical" Width="22" Height="22"/>
                                </materialDesign:PopupBox.ToggleContent>
                                <StackPanel MinWidth="120">
                                    <Button Content="{DynamicResource Common.Edit}"
                                            Command="{Binding DataContext.EditTaskCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            HorizontalContentAlignment="Left"/>
                                    <Button Content="{DynamicResource Common.Delete}"
                                            Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            HorizontalContentAlignment="Left"/>
                                </StackPanel>
                            </materialDesign:PopupBox>
                        </Grid>
                    </materialDesign:Card>
                </DataTemplate>
            </ListView.ItemTemplate>
            
            <ListView.Style>
                <Style TargetType="ListView">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListView">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="TextBoxSearchOutline" Width="80" Height="80" Foreground="{DynamicResource MaterialDesignDivider}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource Tasks.EmptyTitle}" FontSize="18" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                            <TextBlock Text="{DynamicResource Tasks.EmptyHint}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.Style>
        </ListView>
    </Grid>
</UserControl>
