<UserControl x:Class="FolderSync.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource Settings.Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

        <materialDesign:Card Grid.Row="1" Padding="20" UniformCornerRadius="8">
            <StackPanel>
                <CheckBox Content="{DynamicResource Settings.StartWithWindows}" IsChecked="{Binding StartWithWindows}" Margin="0,0,0,12" />
                <CheckBox Content="{DynamicResource Settings.MinimizeToTray}" IsChecked="{Binding MinimizeToTray}" Margin="0,0,0,20" />

                <TextBlock Text="{DynamicResource Settings.LogRetentionDays}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBox Width="180"
                         Text="{Binding LogRetentionDays}"
                         materialDesign:HintAssist.Hint="{DynamicResource Settings.HintDays}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <TextBlock Text="{DynamicResource Settings.Language}" FontWeight="SemiBold" Margin="0,20,0,8" />
                <ComboBox Width="220"
                          ItemsSource="{Binding LanguageOptions}"
                          SelectedValuePath="Code"
                          DisplayMemberPath="DisplayName"
                          SelectedValue="{Binding SelectedLanguage}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                <TextBlock Text="{DynamicResource Settings.FontFamily}" FontWeight="SemiBold" Margin="0,20,0,8" />
                <ComboBox Width="220"
                          ItemsSource="{Binding FontOptions}"
                          SelectedItem="{Binding SelectedFontFamily}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                <TextBlock Text="{DynamicResource Settings.Scale}" FontWeight="SemiBold" Margin="0,20,0,8" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Slider Width="220" Minimum="0.8" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Value="{Binding UiScale}" />
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding UiScale, StringFormat={}{0:F1}x}" />
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{DynamicResource Settings.Save}"
                    Command="{Binding SaveSettingsCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Width="140" />
        </StackPanel>
    </Grid>
</UserControl>
