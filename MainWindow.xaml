<Window x:Class="FolderSync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModels="clr-namespace:FolderSync.UI.ViewModels"
        xmlns:views="clr-namespace:FolderSync.UI.Views"
        mc:Ignorable="d"
        Title="FolderSync Pro" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        TextElement.Foreground="{StaticResource PrimaryTextBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="{DynamicResource AppFontFamily}">

    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <!-- 整个界面的外层布局：左侧导航 + 右侧主内容区域 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppZoomScale}" ScaleY="{DynamicResource AppZoomScale}" />
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <!-- 左侧导航栏的宽度 -->
            <ColumnDefinition Width="250" />
            <!-- 右侧主内容自适应 -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo 区域 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,28,20,24">
                    <materialDesign:PackIcon Kind="FolderSync" Width="32" Height="32" Foreground="{StaticResource SidebarTextBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="FolderSync Pro" FontSize="20" FontWeight="Bold" Foreground="{StaticResource SidebarTextBrush}" Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <!-- 导航菜单 -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    
                    <Button Style="{StaticResource SideNavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" Margin="10,0" />
                            <TextBlock Text="{DynamicResource Nav.Dashboard}" VerticalAlignment="Center" LineHeight="20" LineStackingStrategy="BlockLineHeight" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideNavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Tasks">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FormatListChecks" Width="20" Height="20" Margin="10,0" />
                            <TextBlock Text="{DynamicResource Nav.Tasks}" VerticalAlignment="Center" LineHeight="20" LineStackingStrategy="BlockLineHeight" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideNavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Logs">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocumentMultiple" Width="20" Height="20" Margin="10,0" />
                            <TextBlock Text="{DynamicResource Nav.Logs}" VerticalAlignment="Center" LineHeight="20" LineStackingStrategy="BlockLineHeight" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideNavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Width="20" Height="20" Margin="10,0" />
                            <TextBlock Text="{DynamicResource Nav.Settings}" VerticalAlignment="Center" LineHeight="20" LineStackingStrategy="BlockLineHeight" />
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- 底部信息 -->
                <TextBlock Grid.Row="2" Text="v0.0.18 Beta" Foreground="#BFC7DA" Margin="20,10,20,18" FontSize="12" />
            </Grid>
        </Border>

        <!-- 右侧主内容区域 (动态切换) -->
        <Border Grid.Column="1" Background="{StaticResource AppSurfaceBrush}" CornerRadius="12,0,0,12" Margin="-10,0,0,0">
            <!-- 增加一点阴影让左右层级感更强 -->
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="180" Opacity="0.3" ShadowDepth="2" />
            </Border.Effect>
            
            <Grid Margin="22">
                <!-- DataTemplates mapping ViewModel to View -->
                <ContentControl Content="{Binding CurrentView}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                            <views:DashboardView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type viewModels:TaskEditorViewModel}">
                            <views:TaskEditorView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type viewModels:TasksViewModel}">
                            <views:TasksView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type viewModels:LogsViewModel}">
                            <views:LogsView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
                            <views:SettingsView />
                        </DataTemplate>
                    </ContentControl.Resources>
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentView}" Value="{x:Null}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="RocketLaunch" Width="100" Height="100" Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Center" />
                                                    <TextBlock Text="欢迎使用 FolderSync Pro" FontSize="24" FontWeight="Bold" Margin="0,20,0,10" HorizontalAlignment="Center" />
                                                    <TextBlock Text="请在左侧菜单选择功能模块" FontSize="16" Foreground="Gray" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
