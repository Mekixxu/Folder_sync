<Application x:Class="FolderSync.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:FolderSync.UI.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="/FolderSync;component/UI/Localization/Strings.zh-CN.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global display settings -->
            <FontFamily x:Key="AppFontFamily">Microsoft YaHei UI</FontFamily>
            <sys:Double x:Key="AppZoomScale" xmlns:sys="clr-namespace:System;assembly=mscorlib">1</sys:Double>

            <!-- Human factors: high readability palette -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F6F8FB" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#F8FAFC" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1F2937" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#4B5563" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1F2A44" />
            <SolidColorBrush x:Key="SidebarHoverBrush" Color="#2D3B5F" />
            <SolidColorBrush x:Key="SidebarPressedBrush" Color="#3A4A72" />
            <SolidColorBrush x:Key="SidebarTextBrush" Color="#EEF2FF" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#1B8A5A" />
            <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />
            <SolidColorBrush x:Key="DangerBrush" Color="#B42318" />
            <SolidColorBrush x:Key="InfoBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="ListRowHoverBrush" Color="#EEF2FF" />
            <SolidColorBrush x:Key="ListRowSelectedBrush" Color="#E0E7FF" />

            <!-- Spacing / radius tokens -->
            <sys:Double x:Key="SpaceXs" xmlns:sys="clr-namespace:System;assembly=mscorlib">6</sys:Double>
            <sys:Double x:Key="SpaceSm" xmlns:sys="clr-namespace:System;assembly=mscorlib">10</sys:Double>
            <sys:Double x:Key="SpaceMd" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
            <sys:Double x:Key="SpaceLg" xmlns:sys="clr-namespace:System;assembly=mscorlib">24</sys:Double>
            <sys:Double x:Key="RadiusMd" xmlns:sys="clr-namespace:System;assembly=mscorlib">10</sys:Double>

            <sys:Double x:Key="FontH1" xmlns:sys="clr-namespace:System;assembly=mscorlib">22</sys:Double>
            <sys:Double x:Key="FontH2" xmlns:sys="clr-namespace:System;assembly=mscorlib">17</sys:Double>
            <sys:Double x:Key="FontBody" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
            <sys:Double x:Key="FontMeta" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>

            <!-- Converters used by editor pages -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InvertBooleanConverter x:Key="InvertBooleanConverter" />

            <!-- Consistent side navigation button behavior -->
            <Style x:Key="SideNavButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,4,0,4" />
                <Setter Property="Padding" Value="8,12" />
                <Setter Property="MinHeight" Value="46" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource SidebarPressedBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontH1}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontH2}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Padding" Value="16,8" />
                <Setter Property="Margin" Value="0,0,10,0" />
            </Style>

            <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="Margin" Value="0,0,10,0" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
